# Supabase (hosted cloud project) — copy to .env.local and fill in.
# Project Settings → API → Project URL and anon/public key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google OAuth is configured in the Supabase dashboard:
# Authentication → Providers → Google (paste Google Cloud Client ID + Secret there).
# Add this redirect URL in the Google provider settings and Google Cloud console:
#   http://localhost:3000/auth/callback   (and your production URL)

# Homepage countdown target (ISO-8601). If unset/invalid, a fixed future
# fallback date is used so the countdown never renders blank.
NEXT_PUBLIC_EVENT_DATETIME=2026-12-31T18:30:00+07:00
