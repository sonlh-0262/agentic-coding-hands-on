# Supabase (hosted cloud project) — copy to .env.local and fill in.
# Project Settings → API → Project URL and anon/public key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER ONLY, never prefix with NEXT_PUBLIC_. Bypasses RLS.
# Used by lib/supabase/admin.ts for the Kudos write path (backfilling the
# sender's profile row). Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional: Postgres connection string for applying supabase/migrations via psql.
# Project Settings → Database → Connection string → URI.
# SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres

# Google OAuth is configured in the Supabase dashboard:
# Authentication → Providers → Google (paste Google Cloud Client ID + Secret there).
# Add this redirect URL in the Google provider settings and Google Cloud console:
#   http://localhost:3000/auth/callback   (and your production URL)

# Homepage countdown target (ISO-8601). If unset/invalid, a fixed future
# fallback date is used so the countdown never renders blank.
NEXT_PUBLIC_EVENT_DATETIME=2026-12-31T18:30:00+07:00
